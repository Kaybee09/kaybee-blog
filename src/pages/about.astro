---
import Layout from "../layouts/PageLayout.astro";
import AboutHeroImage from "../assets/blog-placeholder-about.jpg";
---

<Layout title="About Me" description="About Kaybee">

  <section class="about">

    <img src={AboutHeroImage.src} alt="Kaybee" />

    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
    🌙
    </button> 
    <header class="hero"> 
      <h2> <a href="/">Kaybee Lateef</a> </h2> 
      <p>Cloud engineering, Linux, AWS, DevOps, and real project notes.</p> 
      <div class="social-links" aria-label="Social links"> 
        <a href="mailto:kaybeelateef@gmail.com" aria-label="Email" title="Email"> 
          <svg viewBox="0 0 24 24" aria-hidden="true"> <path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm9 8.1L4.4 7H3.8l8.2 6.7L20.2 7h-.6L12 13.1Z"></path> </svg> 
        </a> 
        <a href="https://github.com/Kaybee09" target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub"> 
          <svg viewBox="0 0 24 24" aria-hidden="true"> <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.2.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.5-1.3-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 .1.2 2.6 2.9 1.8.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C16.7 5.3 17.7 5.6 17.7 5.6c.6 1.6.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.2c0 .4.2.7.8.6A12 12 0 0 0 12 .5Z"></path> </svg> 
        </a> 
        <a href="https://www.linkedin.com/in/kaybee/" target="_blank" rel="noreferrer" aria-label="LinkedIn" title="LinkedIn"> 
          <svg viewBox="0 0 24 24" aria-hidden="true"> <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.3 8h4.4v15H.3V8Zm7.1 0h4.2v2.1h.1c.6-1.1 2-2.4 4.2-2.4 4.5 0 5.3 3 5.3 6.8V23h-4.4v-7.5c0-1.8 0-4.1-2.5-4.1s-2.9 2-2.9 4v7.6H7.4V8Z"></path> </svg> 

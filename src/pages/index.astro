---
import "../styles/global.css";

const recentPosts = [
  {
    date: "2026-06-07",
    title: "Building My First AWS Linux Server",
    description:
      "My notes from provisioning a Linux server on AWS, connecting with SSH, configuring security groups, and deploying a landing page.",
    url: "/blog/building-my-first-aws-linux-server/",
  },
  {
    date: "2026-05-24",
    title: "Bash Scripting Notes for Beginners",
    description:
      "Simple Bash scripting examples for automation, file handling, backups, and Linux command-line productivity.",
    url: "/blog/bash-scripting-notes-for-beginners/",
  },
  {
    date: "2026-05-12",
    title: "Dockerizing a Full-Stack App",
    description:
      "How I think about Docker, containers, frontend/backend services, and preparing applications for deployment.",
    url: "/blog/dockerizing-a-full-stack-app/",
  },
];

const projects = [
  {
    title: "AWS Landing Page Deployment",
    description:
      "A Linux server provisioned on AWS with networking, SSH access, and a deployed landing page.",
    url: "/projects/aws-landing-page-deployment/",
  },
  {
    title: "Linux Server Automation",
    description:
      "Practical Bash scripts and notes for automating common Linux server tasks.",
    url: "/projects/linux-server-automation/",
  },
  {
    title: "Docker + GitHub Actions App",
    description:
      "A full-stack project using Docker, GitHub Actions, CI/CD, and cloud deployment.",
    url: "/projects/docker-github-actions-app/",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Kaybee writes practical notes on cloud engineering, Linux, AWS, DevOps, Bash scripting, and real-world projects." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Kaybee Dev — Cloud Engineering Notes</title>
  </head>

  <body>
    <main class="site-container">
      <header class="site-header">
        <h1>
          <a href="/">Kaybee Dev</a>
        </h1>

        <p class="site-tagline">
          Cloud engineering, Linux, AWS, DevOps, and real project notes.
        </p>
      </header>

      <hr />

      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">home</a>
        <a href="/blog/">blog</a>
        <a href="/projects/">projects</a>
        <a href="/about/">about</a>
        <a href="https://github.com/YOUR_GITHUB_USERNAME" target="_blank" rel="noreferrer">github</a>
        <a href="https://www.linkedin.com/in/kaybee/" target="_blank" rel="noreferrer">linkedin</a>
      </nav>

      <section class="intro-section">
        <h2>Hello.</h2>

        <p>
          I write practical notes about my journey into cloud engineering,
          Linux administration, AWS, Bash scripting, Docker, CI/CD, and backend
          projects.
        </p>

        <p>
          This website is where I document what I learn, what I build, and the
          mistakes I fix along the way.
        </p>
      </section>

      <section class="content-section">
        <div class="section-heading">
          <h2>Recent posts</h2>
          <a href="/blog/">all posts</a>
        </div>

        <div class="post-list">
          {recentPosts.map((post) => (
            <article class="post-item">
              <time datetime={post.date}>{post.date}</time>

              <div>
                <h3>
                  <a href={post.url}>{post.title}</a>
                </h3>

                <p>{post.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="content-section">
        <div class="section-heading">
          <h2>Projects</h2>
          <a href="/projects/">all projects</a>
        </div>

        <div class="project-list">
          {projects.map((project) => (
            <article class="project-item">
              <h3>
                <a href={project.url}>{project.title}</a>
              </h3>

              <p>{project.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>What I write about</h2>

        <ul class="topic-list">
          <li>Linux server administration</li>
          <li>AWS and cloud engineering projects</li>
          <li>Bash scripting and automation</li>
          <li>Docker, GitHub Actions, and CI/CD</li>
          <li>Beginner-friendly DevOps notes</li>
        </ul>
      </section>

      <footer class="site-footer">
        <p>
          © 2026 Kaybee.
          <a href="/rss.xml">rss</a>
        </p>
      </footer>
    </main>
  </body>
</html>
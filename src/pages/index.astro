---
import "../styles/global.css";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);

const projects = [
  {
    title: "AWS Landing Page Deployment",
    description:
      "Provisioning a Linux server on AWS, configuring networking, SSH, and deploying a landing page.",
    url: "/projects/aws-landing-page-deployment/",
  },
  {
    title: "Linux Server Automation",
    description:
      "Bash scripts and practical Linux notes for automating server tasks.",
    url: "/projects/linux-server-automation/",
  },
  {
    title: "Docker + GitHub Actions App",
    description:
      "A full-stack application prepared with Docker, CI/CD, and cloud deployment.",
    url: "/projects/docker-github-actions-app/",
  },
];

const formatDate = (date) =>
  new Date(date).toLocaleDateString("en-GB", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Kaybee writes about cloud engineering, Linux, AWS, DevOps, Bash scripting, and real-world projects."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Kaybee Dev — Cloud Engineering Blog</title>

    <script defer src="/theme.js"></script>
  </head>

  <body>
    <main class="page">
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
        🌙
      </button>

      <header class="hero">
        <h1>Kaybee Dev</h1>

        <p>
          Cloud engineering, Linux, AWS, DevOps, and real project notes.
        </p>

        <div class="social-links" aria-label="Social links">
  <a href="mailto:kaybeelateef@gmail.com" aria-label="Email" title="Email">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm9 8.1L4.4 7H3.8l8.2 6.7L20.2 7h-.6L12 13.1Z" />
    </svg>
  </a>

  <a href="https://github.com/YOUR_GITHUB_USERNAME" target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.2.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.5-1.3-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 .1.2 2.6 2.9 1.8.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C16.7 5.3 17.7 5.6 17.7 5.6c.6 1.6.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.2c0 .4.2.7.8.6A12 12 0 0 0 12 .5Z" />
    </svg>
  </a>

  <a href="https://www.linkedin.com/in/kaybee/" target="_blank" rel="noreferrer" aria-label="LinkedIn" title="LinkedIn">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.3 8h4.4v15H.3V8Zm7.1 0h4.2v2.1h.1c.6-1.1 2-2.4 4.2-2.4 4.5 0 5.3 3 5.3 6.8V23h-4.4v-7.5c0-1.8 0-4.1-2.5-4.1s-2.9 2-2.9 4v7.6H7.4V8Z" />
    </svg>
  </a>

  <a href="https://www.tiktok.com/@YOUR_TIKTOK_USERNAME" target="_blank" rel="noreferrer" aria-label="TikTok" title="TikTok">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M16.6 1.5c.3 2.6 1.8 4.2 4.4 4.4v4.1c-1.5.1-2.9-.3-4.3-1.1v6.7c0 8.5-9.3 11.1-13 5.1-2.4-3.9-.9-10.7 6.8-11v4.3c-.5.1-1 .2-1.5.4-1.4.5-2.2 1.8-2 3.2.3 2.7 5.4 3.5 5-1.8V1.5h4.6Z" />
    </svg>
  </a>

  <a href="https://www.instagram.com/YOUR_INSTAGRAM_USERNAME" target="_blank" rel="noreferrer" aria-label="Instagram" title="Instagram">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7Zm5 3.8a4.2 4.2 0 1 1 0 8.4 4.2 4.2 0 0 1 0-8.4Zm0 2a2.2 2.2 0 1 0 0 4.4 2.2 2.2 0 0 0 0-4.4Zm5.4-3.1a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8Z" />
    </svg>
  </a>

  <a href="/rss.xml" aria-label="RSS Feed" title="RSS">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 4.4v3.1c6.9 0 12.5 5.6 12.5 12.5h3.1C19.6 11.4 12.6 4.4 4 4.4Zm0 6.2v3.1c3.5 0 6.3 2.8 6.3 6.3h3.1c0-5.2-4.2-9.4-9.4-9.4ZM6.2 16a2.2 2.2 0 1 0 0 4.4 2.2 2.2 0 0 0 0-4.4Z" />
    </svg>
  </a>
</div>
      </header>

      <hr />

      <section class="nav-section">
  <nav class="main-nav" aria-label="Main navigation">
    <a href="/">Blog</a>
    <a href="#projects">Projects</a>
    <a href="/about/">About</a>
    <a href="/resume/">Resume</a>
  </nav>
</section>

      <section class="intro">
        <p>
          I use this site to document what I am learning and building as I grow
          in cloud engineering. You will find notes on Linux, AWS, Bash,
          Docker, CI/CD, and real projects.
        </p>
      </section>

      <section class="posts">
        {posts.length > 0 ? (
          posts.map((post) => (
            <article class="post-card">
              <header class="post-header">
                <h2>
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>

                <div class="post-meta">
                  <span>{formatDate(post.data.pubDate)}</span>

                  {post.data.tags && (
                    <div class="tags">
                      {post.data.tags.map((tag) => (
                        <span>{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </header>

              <p>{post.data.description}</p>

              <a class="read-more" href={`/blog/${post.slug}/`}>
                ... read more
              </a>
            </article>
          ))
        ) : (
          <article class="post-card">
            <header class="post-header">
              <h2>Building My First AWS Linux Server</h2>

              <div class="post-meta">
                <span>07 Jun 2026</span>

                <div class="tags">
                  <span>aws</span>
                  <span>linux</span>
                  <span>cloud</span>
                </div>
              </div>
            </header>

            <p>
              My notes from provisioning a Linux server on AWS, connecting with
              SSH, configuring security groups, and deploying a landing page.
            </p>

            <a class="read-more" href="#">
              ... read more
            </a>
          </article>
        )}
      </section>

      <section class="projects-section" id="projects">
        <h2>Projects</h2>

        <div class="project-list">
          {projects.map((project) => (
            <article class="project-item">
              <h3>
                <a href={project.url}>{project.title}</a>
              </h3>

              <p>{project.description}</p>
            </article>
          ))}
        </div>
      </section>

      <footer class="footer">
        <p>
          © 2026 Kaybee ·
          <a href="/rss.xml">rss</a>
        </p>
      </footer>
    </main>
  </body>
</html>